  <!-- ############## Thermal Regulator ############## -->

  <HediffDef ParentName="ImplantHediffBase">
    <defName>DRG_hediff_ThermalRegulator</defName>
    <label>thermal regulator</label>
    <labelNoun>a thermal regulator</labelNoun>
    <description>An installed subdermal thermal management system. It actively heats or cools the body to maintain homeostasis in extreme environments. The system draws on the body's metabolic reserves, slightly increasing the recipient's hunger rate.</description>
    <defaultLabelColor>(135,206,235)</defaultLabelColor>
    <stages>
      <li>
        <statOffsets>
          <ComfyTemperatureMin>-40</ComfyTemperatureMin>
          <ComfyTemperatureMax>40</ComfyTemperatureMax>
        </statOffsets>
        <hungerRateFactor>1.15</hungerRateFactor>
      </li>
    </stages>
    <spawnThingOnRemoved>DRG_ThermalRegulator</spawnThingOnRemoved>
    <descriptionHyperlinks>
